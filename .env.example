APP_NAME="Weale Store"
APP_ENV=development
APP_DEBUG=true
APP_PORT=8080
APP_SECRET=your-super-secret-key-here

DB_DRIVER=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=weale_store
DB_USERNAME=weale
DB_PASSWORD=secret

DB_TEST_HOST=db_test
DB_TEST_PORT=5432
DB_TEST_DATABASE=weale_store_test
DB_TEST_USERNAME=weale
DB_TEST_PASSWORD=secret

REDIS_HOST=redis
REDIS_PORT=6379

JWT_SECRET=your-jwt-secret-key
JWT_EXPIRATION=3600
