{
    "name": "weale/store-back",
    "description": "Weale Store Backend - PHP Slim with DDD",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "doctrine/dbal": "^3.8",
        "doctrine/migrations": "^3.7",
        "doctrine/orm": "^3.1",
        "firebase/php-jwt": "^6.10",
        "monolog/monolog": "^3.5",
        "php-di/php-di": "^7.0",
        "ramsey/uuid": "^4.7",
        "respect/validation": "^2.3",
        "slim/psr7": "^1.6",
        "slim/slim": "^4.13",
        "symfony/cache": "^7.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.9",
        "mockery/mockery": "^1.6",
        "fakerphp/faker": "^1.23",
        "phpunit/php-code-coverage": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Weale\\Bootstrap\\": "bootstrap/",
            "Weale\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Weale\\Tests\\": "tests/",
            "Weale\\Tests\\Helpers\\": "tests/Helpers/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "test:coverage": "phpunit --coverage-html coverage/",
        "lint": "phpcs --standard=PSR12 src/ tests/",
        "analyse": "phpstan analyse src/ --level=8",
        "migrations:run": "php vendor/bin/doctrine-migrations migrate --no-interaction --configuration config/migrations.php --db-configuration migrations-db.php",
        "migrations:rollback": "php vendor/bin/doctrine-migrations migrate prev --no-interaction --configuration config/migrations.php --db-configuration migrations-db.php",
        "migrations:create": "php vendor/bin/doctrine-migrations generate --configuration config/migrations.php --db-configuration migrations-db.php",
        "migrations:status": "php vendor/bin/doctrine-migrations status --configuration config/migrations.php --db-configuration migrations-db.php"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
